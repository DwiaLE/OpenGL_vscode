{
    "code-runner.runInTerminal": true,
    "code-runner.fileDirectoryAsCwd": false,
    "code-runner.ignoreSelection": true,
    "code-runner.showExecutionMessage": true,
    "code-runner.executorMap": {
        "c": "Set-Location -LiteralPath \"$dir\"; gcc -g \"$fileName\" -o \"$fileNameWithoutExt\"; if ($LASTEXITCODE -eq 0) { & \".\\\\$fileNameWithoutExt.exe\" }",
        "cpp": "Set-Location -LiteralPath \"$dir\"; g++ -std=c++14 -g \"$fileName\" -o \"$fileNameWithoutExt\" -I\"$workspaceRoot\\\\Dependencies\\\\GLFW\\\\include\" -L\"$workspaceRoot\\\\Dependencies\\\\GLFW\\\\lib\" -lglfw3 -lopengl32 -lgdi32; if ($LASTEXITCODE -eq 0) { & \".\\\\$fileNameWithoutExt.exe\" }"
    }
}

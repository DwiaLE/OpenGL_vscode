{
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: cl.exe 生成 Application",
            "command": "call",
            "args": [
                "\"G:\\Visual studio\\software\\VC\\Auxiliary\\Build\\vcvars64.bat\"",
                "&&",
                "cl",
                "/std:c++17",
                "/utf-8",
                "/MD",
                "/Zi",
                "/EHsc",
                "/I",
                "\"${workspaceFolder}\\Dependencies\\GLFW\\include\"",
                "/I",
                "\"${workspaceFolder}\\Dependencies\\GLEW\\include\"",
                "/D",
                "GLEW_STATIC",
                "\"${workspaceFolder}\\src\\*.cpp\"",
                "/link",
                "/OUT:\"${workspaceFolder}\\src\\Application.exe\"",
                "/LIBPATH:\"${workspaceFolder}\\Dependencies\\GLFW\\lib-vc2022\"",
                "/LIBPATH:\"${workspaceFolder}\\Dependencies\\GLEW\\lib\\Release\\x64\"",
                "glfw3.lib",
                "glew32s.lib",
                "opengl32.lib",
                "gdi32.lib",
                "user32.lib",
                "shell32.lib"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "C:\\Windows\\System32\\cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}

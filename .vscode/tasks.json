{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe 生成活动文件",
            "command": "C:\\MinGW64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-std=c++14",
                "-g",
                "${workspaceFolder}\\src\\*.cpp",
                "-o",
                "${workspaceFolder}\\src\\${fileBasenameNoExtension}.exe",
                "-I${workspaceFolder}\\Dependencies\\GLFW\\include",
                "-L${workspaceFolder}\\Dependencies\\GLFW\\lib",
                "-I${workspaceFolder}\\Dependencies\\GLEW\\include",
                "-L${workspaceFolder}\\Dependencies\\GLEW\\lib\\Release\\x64",
                "-lglew32s",
                "-lglfw3",
                "-lopengl32",
                "-lgdi32",
                "-DGLEW_STATIC"

            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}
